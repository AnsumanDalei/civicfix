DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=1

# --- Locale (not hardcoded to any country — set these for your region) ---
DJANGO_TIME_ZONE=UTC
DJANGO_LANGUAGE_CODE=en-us

# --- Escalation tier names (match your local civic structure) ---
# Examples:
#   India:  TIER_1_NAME=Ward Officer        TIER_2_NAME=District Head           TIER_3_NAME=Municipal Commissioner
#   USA:    TIER_1_NAME=Ward Council        TIER_2_NAME=City Council            TIER_3_NAME=Mayor's Office
#   UK:     TIER_1_NAME=Local Councillor    TIER_2_NAME=Borough Council         TIER_3_NAME=Ombudsman
TIER_1_NAME=Local Authority
TIER_2_NAME=Regional Authority
TIER_3_NAME=Top Authority

# --- Default map center (shown before geolocation resolves) ---
# Defaults to a neutral world view. Set to your city's coordinates so the
# report form opens centered on your area instead:
DEFAULT_MAP_LAT=20.0
DEFAULT_MAP_LNG=0.0
DEFAULT_MAP_ZOOM=2

# Set DB_ENGINE=oracle to switch off SQLite (see civicfix/settings.py)
DB_ENGINE=sqlite
ORACLE_DSN=localhost:1521/XEPDB1
ORACLE_USER=civicfix
ORACLE_PASSWORD=civicfix
